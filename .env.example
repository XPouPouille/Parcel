# Domaine exposé par Traefik (ex: parcel.mondomaine.com — sans https://)
APP_DOMAIN=parcel.your-domain.com

# URL publique complète (utilisée par le bot Telegram pour les liens)
APP_URL=https://parcel.your-domain.com

PORT=3000

# Clé API 17track (gratuit sur https://www.17track.net/en/api)
TRACK17_API_KEY=your_17track_api_key_here

# Bot Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Intervalle de vérification en minutes (défaut: 60)
CHECK_INTERVAL_MINUTES=60
