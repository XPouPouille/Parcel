# Domaine Traefik (sans https://)
APP_DOMAIN=parcel.your-domain.com

# URL complète (pour les liens dans les notifications Telegram)
APP_URL=https://parcel.your-domain.com

PORT=3000

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot créé via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
# ID du chat qui reçoit les notifications (envoyer /start au bot pour l'obtenir)
TELEGRAM_CHAT_ID=123456789

# Intervalle de vérification en minutes (défaut: 60, modifiable dans l'interface)
CHECK_INTERVAL_MINUTES=60

# ── APIs transporteurs ────────────────────────────────────────────────────────
# Les clés non renseignées désactivent le transporteur concerné (affiche "non configuré")

# La Poste / Colissimo / Chronopost — inscription gratuite : developer.laposte.fr
LAPOSTE_API_KEY=

# DHL Express — inscription gratuite : developer.dhl.com
DHL_API_KEY=

# UPS — inscription gratuite : developer.ups.com
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=

# FedEx (inclut TNT) — inscription gratuite : developer.fedex.com
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=

# USPS — inscription gratuite : registration.shippingapis.com
USPS_USER_ID=

# PostNL — inscription gratuite : developer.postnl.nl
POSTNL_API_KEY=

# ── Sans clé (fonctionnent directement) ──────────────────────────────────────
# GLS       → endpoint public, aucune clé requise
# Mondial Relay → endpoint interne, peut nécessiter un code postal destinataire
# DPD       → endpoint public, aucune clé requise
